@@ -103,6 +103,7 @@
 find_program(MAKE_EXECUTABLE NAMES make REQUIRED)
 
 ProcessorCount(PAR_JOBS)
+set(ROCGDB_MAKE_JOBS "${PAR_JOBS}" CACHE STRING "Parallel jobs for ROCgdb's recursive make")
 
 # Configure build type flags.
 if(NOT CMAKE_BUILD_TYPE)
@@ -198,12 +199,38 @@
   message(STATUS "Adding sanitizer RPATH for configure/build: ${SANITIZER_RPATH}")
 endif()
 
+set(ROCGDB_EXTRA_LDFLAGS "" CACHE STRING "Extra linker flags to pass to ROCgdb configure")
+set(ROCGDB_EXTRA_CPPFLAGS "" CACHE STRING "Extra preprocessor flags to pass to ROCgdb configure")
+set(ROCGDB_EXTRA_PKG_CONFIG_PATH "" CACHE STRING "Extra pkg-config search path to pass to ROCgdb configure")
+set(ROCGDB_FILE_CMD "file" CACHE FILEPATH "file(1) executable to pass to libtool configure probes")
+set(ROCGDB_GMP_INCLUDE_DIR "" CACHE PATH "GMP include directory to pass to ROCgdb configure")
+set(ROCGDB_GMP_LIBRARY_DIR "" CACHE PATH "GMP library directory to pass to ROCgdb configure")
+set(ROCGDB_MPFR_INCLUDE_DIR "" CACHE PATH "MPFR include directory to pass to ROCgdb configure")
+set(ROCGDB_MPFR_LIBRARY_DIR "" CACHE PATH "MPFR library directory to pass to ROCgdb configure")
+
+if(ROCGDB_EXTRA_CPPFLAGS)
+  string(APPEND CUSTOM_C_FLAGS " ${ROCGDB_EXTRA_CPPFLAGS}")
+  string(APPEND CUSTOM_CXX_FLAGS " ${ROCGDB_EXTRA_CPPFLAGS}")
+endif()
+set(CUSTOM_CPP_FLAGS "${CUSTOM_C_FLAGS}")
+
 # Adjust LDFLAGS. NCURSES_RPATH and SANITIZER_RPATH are empty when not using bundled sysdeps or sanitizers.
-set(LDFLAGS "${CMAKE_SHARED_LINKER_FLAGS} ${NCURSES_RPATH} ${SANITIZER_RPATH} -Wl,--enable-new-dtags")
+set(LDFLAGS "${CMAKE_EXE_LINKER_FLAGS} ${CMAKE_SHARED_LINKER_FLAGS} ${ROCGDB_EXTRA_LDFLAGS} ${NCURSES_RPATH} ${SANITIZER_RPATH} -Wl,--enable-new-dtags")
+
+# TheRock exposes private stage libraries with -rpath-link, but ROCgdb's
+# configure probes immediately execute their linked test binaries.
+string(REGEX REPLACE "-Wl,-rpath-link,([^ ]+)" "-Wl,-rpath-link,\\1 -Wl,-rpath,\\1" LDFLAGS "${LDFLAGS}")
 
 # Replace all semicolons (the CMake separator) with colons (the ENV separator).
 # We need this to pass it on to rocgdb's configure.
 string(REPLACE ";" ":" PKG_CONFIG_PATH_ENV_VAR "${THEROCK_PKG_CONFIG_DIRS}")
+if(ROCGDB_EXTRA_PKG_CONFIG_PATH)
+  if(PKG_CONFIG_PATH_ENV_VAR)
+    string(APPEND PKG_CONFIG_PATH_ENV_VAR ":${ROCGDB_EXTRA_PKG_CONFIG_PATH}")
+  else()
+    set(PKG_CONFIG_PATH_ENV_VAR "${ROCGDB_EXTRA_PKG_CONFIG_PATH}")
+  endif()
+endif()
 
 # Set conditional configure flags for bundled sysdep prefixes. When using system
 # libraries, these are left empty so autotools discovers them via pkg-config.
@@ -214,6 +241,14 @@
   set(ROCGDB_EXPAT_FLAG "--with-expat-prefix=${EXPAT_PREFIX}")
   set(ROCGDB_GMP_FLAG "--with-gmp=${GMP_PREFIX}")
   set(ROCGDB_MPFR_FLAG "--with-mpfr=${MPFR_PREFIX}")
+elseif(ROCGDB_GMP_INCLUDE_DIR AND ROCGDB_GMP_LIBRARY_DIR AND
+       ROCGDB_MPFR_INCLUDE_DIR AND ROCGDB_MPFR_LIBRARY_DIR)
+  set(ROCGDB_GMP_FLAG
+      "--with-gmp-include=${ROCGDB_GMP_INCLUDE_DIR}"
+      "--with-gmp-lib=${ROCGDB_GMP_LIBRARY_DIR}")
+  set(ROCGDB_MPFR_FLAG
+      "--with-mpfr-include=${ROCGDB_MPFR_INCLUDE_DIR}"
+      "--with-mpfr-lib=${ROCGDB_MPFR_LIBRARY_DIR}")
 endif()
 
 # Build RPATH segments from THEROCK_PRIVATE_INSTALL_RPATH_DIRS if defined.
