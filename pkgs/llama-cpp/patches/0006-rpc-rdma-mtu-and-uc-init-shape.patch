+static enum ibv_mtu rdma_default_path_mtu(enum ibv_mtu active_mtu) {
+    return active_mtu < IBV_MTU_1024 ? active_mtu : IBV_MTU_1024;
+}
+
+static enum ibv_mtu rdma_path_mtu(enum ibv_mtu active_mtu) {
+    const char * env = std::getenv("GGML_RDMA_PATH_MTU");
+    if (!env || !*env) {
+        return rdma_default_path_mtu(active_mtu);
+    }
+
+    errno = 0;
+    char * end = nullptr;
+    unsigned long parsed = std::strtoul(env, &end, 10);
+    if (errno != 0 || end == env || *end != '\0') {
+        GGML_LOG_ERROR("Ignoring invalid GGML_RDMA_PATH_MTU=%s\n", env);
+        return rdma_default_path_mtu(active_mtu);
+    }
+
+    switch (parsed) {
+        case 256:  return IBV_MTU_256;
+        case 512:  return IBV_MTU_512;
+        case 1024: return IBV_MTU_1024;
+        case 2048: return IBV_MTU_2048;
+        case 4096: return IBV_MTU_4096;
+        default:
+            GGML_LOG_ERROR("Ignoring invalid GGML_RDMA_PATH_MTU=%s\n", env);
+            return rdma_default_path_mtu(active_mtu);
+    }
+}
