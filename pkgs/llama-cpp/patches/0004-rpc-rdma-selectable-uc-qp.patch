+static enum ibv_qp_type rdma_qp_type() {
+    const char * env = std::getenv("GGML_RDMA_QP_TYPE");
+    if (env && (strcmp(env, "UC") == 0 || strcmp(env, "uc") == 0)) {
+        return IBV_QPT_UC;
+    }
+    return IBV_QPT_RC;
+}
+
+static const char * rdma_qp_type_name(enum ibv_qp_type qp_type) {
+    return qp_type == IBV_QPT_UC ? "UC" : "RC";
+}
