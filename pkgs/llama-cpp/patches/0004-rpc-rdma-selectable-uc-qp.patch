+    const bool use_uc = rdma->qp_type == IBV_QPT_UC;
+    GGML_LOG_INFO("RDMA activate starting: qp_type=%s qpn=%u->%u\n",
+                  rdma_qp_type_name(rdma->qp_type), rdma_local.qpn, remote_qpn);
     // RESET -> INIT
     {
         struct ibv_qp_attr a = {};
         a.qp_state        = IBV_QPS_INIT;
         a.port_num        = rdma_local.ib_port;
         a.pkey_index      = 0;
-        a.qp_access_flags = IBV_ACCESS_REMOTE_WRITE | IBV_ACCESS_REMOTE_READ | IBV_ACCESS_LOCAL_WRITE;
+        a.qp_access_flags = IBV_ACCESS_REMOTE_WRITE | IBV_ACCESS_LOCAL_WRITE;
+        if (!use_uc) {
+            a.qp_access_flags |= IBV_ACCESS_REMOTE_READ;
+        }
+        errno = 0;
         if (ibv_modify_qp(rdma->qp, &a,
                 IBV_QP_STATE | IBV_QP_PKEY_INDEX | IBV_QP_PORT | IBV_QP_ACCESS_FLAGS) != 0) {
+            GGML_LOG_ERROR("RDMA activate failed at INIT: errno=%d (%s)\n", errno, strerror(errno));
             return false;
         }
     }

     for (int i = 0; i < RDMA_RX_DEPTH; i++) {
-        if (!rdma->post_rx(i)) return false;
+        if (!rdma->post_rx(i)) {
+            GGML_LOG_ERROR("RDMA activate failed posting receive slot %d\n", i);
+            return false;
+        }
     }

     // INIT -> RTR
