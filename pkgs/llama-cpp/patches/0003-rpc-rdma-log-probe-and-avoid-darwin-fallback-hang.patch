+bool socket_t::impl::rdma_probe_fail(const char * stage) {
+    const int err = errno;
+    if (err != 0) {
+        GGML_LOG_ERROR("RDMA probe failed at %s: errno=%d (%s)\n", stage, err, strerror(err));
+    } else {
+        GGML_LOG_ERROR("RDMA probe failed at %s\n", stage);
+    }
+    rdma_reset_for_fallback(stage);
+    return false;
+}
+
+void socket_t::impl::rdma_reset_for_fallback(const char * reason) {
+#ifdef __APPLE__
+    if (rdma) {
+        GGML_LOG_ERROR("RDMA fallback on Darwin after %s; releasing speculative verbs state to avoid provider cleanup hang\n",
+                       reason);
+        (void)rdma.release();
+        return;
+    }
+#else
+    (void)reason;
+#endif
+    rdma.reset();
+}
