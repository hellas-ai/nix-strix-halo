+        set(GGML_RPC_RDMA_LIBRARY_NAME ibverbs)
+    endif()
+
+    find_library(GGML_RPC_RDMA_LIB ${GGML_RPC_RDMA_LIBRARY_NAME})
-    if (IBVERBS_LIB)
