         option(GGML_RPC_RDMA "ggml: enable RDMA transport for RPC" ON)
     else()
         option(GGML_RPC_RDMA "ggml: enable RDMA transport for RPC" OFF)
     endif()
-else()
-    set(GGML_RPC_RDMA OFF CACHE BOOL "RDMA not available on this platform" FORCE)
 endif()
 
 if (GGML_RPC_RDMA)
-    if (NOT IBVERBS_LIB)
