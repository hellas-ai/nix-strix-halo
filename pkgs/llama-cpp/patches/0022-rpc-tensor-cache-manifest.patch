+using rpc_tensor_hash_fn = uint64_t (*)(const void * data, size_t size);
+using rpc_buffer_set_tensor_hash_fn = bool (*)(ggml_backend_buffer_t buffer, ggml_tensor * tensor, size_t offset, size_t size, uint64_t hash);
+
+struct rpc_tensor_cache_fns {
+    rpc_tensor_hash_fn hash = nullptr;
+    rpc_buffer_set_tensor_hash_fn set_tensor_hash = nullptr;
+};
+
+static rpc_tensor_cache_fns rpc_tensor_cache_get_fns() {
+    rpc_tensor_cache_fns result;
+    ggml_backend_reg_t reg = ggml_backend_reg_by_name("RPC");
+    if (reg == nullptr) {
+        return result;
+    }
+    result.hash = (rpc_tensor_hash_fn) ggml_backend_reg_get_proc_address(reg, "ggml_backend_rpc_tensor_hash");
+    result.set_tensor_hash = (rpc_buffer_set_tensor_hash_fn) ggml_backend_reg_get_proc_address(reg, "ggml_backend_rpc_buffer_set_tensor_hash");
+    return result;
+}
+
+struct rpc_tensor_cache_manifest {
+    bool enabled = false;
+    std::string path;
+    std::unordered_map<std::string, uint64_t> hashes;
+    std::ofstream out;
+
+    rpc_tensor_cache_manifest() {
+        const char * env = std::getenv("GGML_RPC_TENSOR_CACHE_MANIFEST");
+        if (env == nullptr || env[0] == '\0') {
+            return;
+        }
+
+        enabled = true;
+        path = env;
+
+        std::ifstream in(path);
+        std::string hash_str;
+        uint32_t idx = 0;
+        size_t offs = 0;
+        size_t size = 0;
+        std::string name;
+        while (in >> hash_str >> idx >> offs >> size >> name) {
+            char * end = nullptr;
+            uint64_t hash = std::strtoull(hash_str.c_str(), &end, 16);
+            if (end != hash_str.c_str() && end != nullptr && *end == '\0') {
+                hashes[key(idx, offs, size, name.c_str())] = hash;
+            }
+        }
+
+        out.open(path, std::ios::out | std::ios::app);
+        if (!out) {
+            LLAMA_LOG_WARN("%s: failed to open RPC tensor cache manifest for append: %s\n", __func__, path.c_str());
+        }
+    }
+
+    static std::string key(uint16_t idx, size_t offs, size_t size, const char * name) {
+        return std::to_string(idx) + ":" + std::to_string(offs) + ":" + std::to_string(size) + ":" + name;
+    }
+
+    bool get(uint16_t idx, size_t offs, size_t size, const char * name, uint64_t & hash) const {
+        auto it = hashes.find(key(idx, offs, size, name));
+        if (it == hashes.end()) {
+            return false;
+        }
+        hash = it->second;
+        return true;
+    }
+
+    void put(uint16_t idx, size_t offs, size_t size, const char * name, uint64_t hash) {
+        std::string k = key(idx, offs, size, name);
+        auto it = hashes.find(k);
+        if (it != hashes.end() && it->second == hash) {
+            return;
+        }
+        hashes[k] = hash;
+
+        if (!out) {
+            return;
+        }
+        char hash_str[17];
+        snprintf(hash_str, sizeof(hash_str), "%016" PRIx64, hash);
+        out << hash_str << ' ' << idx << ' ' << offs << ' ' << size << ' ' << name << '\n';
+        out.flush();
+    }
+};
 
