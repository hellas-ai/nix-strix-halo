+static int rdma_ack_every() {
+    const char * env = std::getenv("GGML_RPC_RDMA_ACK_EVERY");
+    if (!env || !*env) {
+        return RDMA_ACK_EVERY_DEFAULT;
+    }
+    errno = 0;
+    char * end = nullptr;
+    unsigned long parsed = std::strtoul(env, &end, 10);
+    if (errno != 0 || end == env || *end != '\0' || parsed == 0 || parsed > 65535) {
+        GGML_LOG_ERROR("Ignoring invalid GGML_RPC_RDMA_ACK_EVERY=%s\n", env);
+        return RDMA_ACK_EVERY_DEFAULT;
+    }
+    return static_cast<int>(parsed);
+}
+
+static int rdma_ack_window() {
