+static int rdma_tx_depth(int fallback) {
+    const char * env = std::getenv("GGML_RPC_RDMA_TX_DEPTH");
+    if (!env || !*env) {
+        return fallback;
+    }
+    errno = 0;
+    char * end = nullptr;
+    unsigned long parsed = std::strtoul(env, &end, 10);
+    if (errno != 0 || end == env || *end != '\0' || parsed == 0 || parsed > 65535) {
+        GGML_LOG_ERROR("Ignoring invalid GGML_RPC_RDMA_TX_DEPTH=%s\n", env);
+        return fallback;
+    }
+    return static_cast<int>(parsed);
+}
