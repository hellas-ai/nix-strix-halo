@@ -91,6 +91,23 @@ static const char * rdma_qp_type_name(enum ibv_qp_type qp_type) {
     return qp_type == IBV_QPT_UC ? "UC" : "RC";
 }

+static uint16_t rdma_remote_lid() {
+    const char * env = std::getenv("GGML_RDMA_REMOTE_LID");
+    if (!env || !*env) {
+        return 0;
+    }
+
+    errno = 0;
+    char * end = nullptr;
+    unsigned long parsed = std::strtoul(env, &end, 10);
+    if (errno != 0 || end == env || *end != '\0' || parsed > 0xffff) {
+        GGML_LOG_ERROR("Ignoring invalid GGML_RDMA_REMOTE_LID=%s\n", env);
+        return 0;
+    }
+
+    return static_cast<uint16_t>(parsed);
+}
