+static uint32_t rdma_psn(uint32_t fallback) {
+    const char * env = std::getenv("GGML_RDMA_PSN");
+    if (env && *env) {
+        errno = 0;
+        char * end = nullptr;
+        unsigned long parsed = std::strtoul(env, &end, 10);
+        if (errno == 0 && end != env && *end == '\0' && parsed <= 0xffffff) {
+            return static_cast<uint32_t>(parsed);
+        }
+
+        GGML_LOG_ERROR("Ignoring invalid GGML_RDMA_PSN=%s\n", env);
+    }
+
+    static std::atomic<uint32_t> next_psn{0};
+    uint32_t seed = (fallback ^ (uint32_t)time(nullptr) ^ 0x4d3a5b7u) & 0xffffff;
+    if (seed == 0) seed = 1;
+    uint32_t expected = 0;
+    next_psn.compare_exchange_strong(expected, seed, std::memory_order_relaxed);
+    uint32_t psn = next_psn.fetch_add(1, std::memory_order_relaxed) & 0xffffff;
+    return psn == 0 ? 1 : psn;
+}
