+static int rdma_rx_depth() {
+    const char * env = std::getenv("GGML_RPC_RDMA_RX_DEPTH");
+    if (!env || !*env) {
+        return RDMA_DEFAULT_RX_DEPTH;
+    }
+    errno = 0;
+    char * end = nullptr;
+    unsigned long parsed = std::strtoul(env, &end, 10);
+    if (errno != 0 || end == env || *end != '\0' || parsed == 0 || parsed > 65535) {
+        GGML_LOG_ERROR("Ignoring invalid GGML_RPC_RDMA_RX_DEPTH=%s\n", env);
+        return RDMA_DEFAULT_RX_DEPTH;
+    }
+    return static_cast<int>(parsed);
+}
