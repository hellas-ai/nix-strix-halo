+bool socket_t::impl::rdma_post_fixed_frame(uint8_t * frame, size_t wire_chunk) {
+    rdma_conn * c = rdma.get();
+
+    struct ibv_sge sge = {};
+    sge.addr   = (uintptr_t)frame;
+    sge.length = wire_chunk;
+    sge.lkey   = c->tx_mr->lkey;
+
+    struct ibv_send_wr wr = {}, * bad = nullptr;
+    wr.wr_id      = wire_chunk;
+    wr.opcode     = IBV_WR_SEND;
+    wr.sg_list    = &sge;
+    wr.num_sge    = 1;
+    wr.send_flags = IBV_SEND_SIGNALED;
+
+    errno = 0;
+    if (ibv_post_send(c->qp, &wr, &bad) != 0) {
+        GGML_LOG_ERROR("RDMA fixed-frame post_send failed: wire_chunk=%zu errno=%d (%s)\n",
+                       wire_chunk, errno, strerror(errno));
+        return false;
+    }
+
+    struct ibv_wc wc;
+    return rdma_poll(c->scq, &wc);
+}
+
+bool socket_t::impl::rdma_send_fixed_ack(uint64_t seq) {
+    rdma_conn * c = rdma.get();
+    uint8_t * frame = c->tx_slot(c->tx_head);
+    c->tx_head = (c->tx_head + 1) % c->tx_depth;
+    rdma_write_frame_header(frame, RDMA_FRAME_ACK, seq);
+    memset(frame + RDMA_FRAME_HEADER, 0, c->frame_payload_size());
+
+    if (!rdma_post_fixed_frame(frame, c->chunk_size)) {
+        return false;
+    }
+    if (rdma_trace_io()) {
+        GGML_LOG_ERROR("RDMA fixed-frame ACK sent: seq=%llu\n",
+                       (unsigned long long)seq);
+    }
+    return true;
+}
