+bool socket_t::impl::rdma_poll_timeout(struct ibv_cq * cq, struct ibv_wc * wc, uint64_t timeout_us, bool * timed_out) {
+    struct timespec start = {};
+    if (timed_out) {
+        *timed_out = false;
+    }
+    clock_gettime(CLOCK_MONOTONIC, &start);
+
+    for (uint64_t s = 0; ; s++) {
+        int n = ibv_poll_cq(cq, 1, wc);
+        if (n > 0) {
+            if (wc->status != IBV_WC_SUCCESS) {
+                GGML_LOG_ERROR("RDMA CQ wc error: status=%d (%s) vendor_err=0x%x\n",
+                    wc->status, ibv_wc_status_str(wc->status), wc->vendor_err);
+            }
+            return wc->status == IBV_WC_SUCCESS;
+        }
+        if (n < 0) return false;
+        if ((s & 0x3FFF) == 0 && s > 0) {
+            struct timespec now = {};
+            if (tcp_peer_closed()) {
+                return false;
+            }
+            clock_gettime(CLOCK_MONOTONIC, &now);
+            int64_t elapsed_us =
+                (int64_t)(now.tv_sec - start.tv_sec) * 1000000ll +
+                (int64_t)(now.tv_nsec - start.tv_nsec) / 1000ll;
+            if (elapsed_us >= 0 && (uint64_t)elapsed_us >= timeout_us) {
+                if (timed_out) {
+                    *timed_out = true;
+                }
+                return false;
+            }
+        }
+    }
+}
