+bool socket_t::impl::rdma_wait_fixed_ack(uint64_t seq, uint8_t * frame, size_t wire_chunk) {
+    rdma_conn * c = rdma.get();
+    const uint64_t timeout_us = rdma_ack_timeout_us();
+    const int max_retries = rdma_ack_retries();
+    int retries = 0;
+
+    for (;;) {
+        struct ibv_wc wc;
+        bool timed_out = false;
+        if (!rdma_poll_timeout(c->rcq, &wc, timeout_us, &timed_out)) {
+            if (!timed_out) {
+                return false;
+            }
+            if (retries >= max_retries) {
+                GGML_LOG_ERROR("RDMA fixed-frame ACK timeout: seq=%llu retries=%d timeout_us=%llu\n",
+                               (unsigned long long)seq, retries,
+                               (unsigned long long)timeout_us);
+                return false;
+            }
+            retries++;
+            if (rdma_trace_io() || retries == 1) {
+                GGML_LOG_WARN("RDMA fixed-frame retransmit: seq=%llu retry=%d timeout_us=%llu\n",
+                              (unsigned long long)seq, retries,
+                              (unsigned long long)timeout_us);
+            }
+            if (!rdma_post_fixed_frame(frame, wire_chunk)) {
+                return false;
+            }
+            continue;
+        }
+
+        int slot = (int)wc.wr_id;
+        size_t got = wc.byte_len;
+        if (got != c->chunk_size) {
+            GGML_LOG_ERROR("RDMA fixed-frame ACK wait got unexpected byte count: got=%zu expected=%zu\n",
+                           got, c->chunk_size);
+            return false;
+        }
+
+        const uint8_t * rx_frame = c->rx_slot(slot);
+        size_t payload = 0;
+        uint64_t rx_seq = 0;
+        if (!rdma_read_frame_header(rx_frame, &payload, &rx_seq) ||
+            (!rdma_frame_is_ack(payload) && payload > c->frame_payload_size())) {
+            GGML_LOG_ERROR("RDMA fixed-frame ACK wait got invalid header: got=%zu payload=%zu seq=%llu\n",
+                           got, payload, (unsigned long long)rx_seq);
+            return false;
+        }
+
+        if (rdma_frame_is_ack(payload)) {
+            if (!c->post_rx(slot)) {
+                return false;
+            }
+            if (rx_seq == seq) {
+                if (rdma_trace_io()) {
+                    GGML_LOG_ERROR("RDMA fixed-frame ACK received: seq=%llu retries=%d\n",
+                                   (unsigned long long)seq, retries);
+                }
+                return true;
+            }
+            if (rx_seq < seq) {
+                if (rdma_trace_io()) {
+                    GGML_LOG_ERROR("RDMA fixed-frame stale ACK skipped: ack_seq=%llu want=%llu\n",
+                                   (unsigned long long)rx_seq,
+                                   (unsigned long long)seq);
+                }
+                continue;
+            }
+            GGML_LOG_ERROR("RDMA fixed-frame future ACK: ack_seq=%llu want=%llu\n",
+                           (unsigned long long)rx_seq, (unsigned long long)seq);
+            return false;
+        }
+
+        if (rx_seq < c->rx_seq) {
+            if (!c->post_rx(slot)) {
+                return false;
+            }
+            if (c->send_frame_ack && !rdma_send_fixed_ack(rx_seq)) {
+                return false;
+            }
+            if (rdma_trace_io()) {
+                GGML_LOG_ERROR("RDMA fixed-frame duplicate buffered-side drop: seq=%llu expected=%llu\n",
+                               (unsigned long long)rx_seq,
+                               (unsigned long long)c->rx_seq);
+            }
+            continue;
+        }
+        if (rx_seq > c->rx_seq) {
+            GGML_LOG_ERROR("RDMA fixed-frame out-of-order while waiting ACK: got=%llu expected=%llu\n",
+                           (unsigned long long)rx_seq,
+                           (unsigned long long)c->rx_seq);
+            return false;
+        }
+        if (c->rx_pending_len != 0) {
+            GGML_LOG_ERROR("RDMA fixed-frame ACK wait received data while pending data is buffered\n");
+            return false;
+        }
+        memcpy(c->rx_pending.data(), rx_frame + RDMA_FRAME_HEADER, payload);
+        c->rx_pending_off = 0;
+        c->rx_pending_len = payload;
+        c->rx_seq++;
+        if (!c->post_rx(slot)) {
+            return false;
+        }
+        if (c->send_frame_ack && !rdma_send_fixed_ack(rx_seq)) {
+            return false;
+        }
+        if (rdma_trace_io()) {
+            GGML_LOG_ERROR("RDMA fixed-frame ACK wait buffered payload=%zu seq=%llu\n",
+                           payload, (unsigned long long)rx_seq);
+        }
+    }
+}
